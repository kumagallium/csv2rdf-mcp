@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sd: <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology.owl.ttl> a owl:Ontology ;
    rdfs:label "starrydata" ;
    dcterms:license "https://www.apache.org/licenses/LICENSE-2.0" ;
    dcterms:title "Starrydata Ontology (LinkML rewrite)" ;
    pav:version "0.1.0" ;
    skos:definition """LinkML rewrite of docs/ontology/starrydata.ttl for Phase 3 evaluation. The
goal is to determine whether a single model.yaml can replace the four hand-
authored artifacts (TBox / Mermaid / MIE shape_expressions / Python class
scaffolds) that currently have to be kept in sync.

Caveats:
- LinkML's ShEx generator emits a single shape per class — the MIE
  shape_expressions block in Phase 1 nested PersonShape inside PaperShape
  via @<...>, which is also expressible here.
- LinkML does not model "composite IRI key" directly. We capture the key
  composition via `id_prefixes` and a free-form comment instead.
- bnode-free is enforced by giving every class an `identifier: true` slot.
""" .

sd:Curve a owl:Class ;
    rdfs:label "Curve" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:rawFigureId ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:xValuesJSON ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:double ;
            owl:onProperty sd:yMin ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:curveCompositeKey ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:propertyX ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:curveCompositeKey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:yValuesJSON ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:unitXString ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:unitXString ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:xMax ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:pointCount ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:xValuesJSON ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:comments ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:xMin ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:curveCompositeKey ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:figureName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:projectName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:projectName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:unitXString ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:yValuesJSON ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:propertyY ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:yMax ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:yValuesJSON ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:unitYString ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:xValuesJSON ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:comments ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:propertyX ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:propertyX ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:ofSample ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:ofSample ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:figureName ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:rawFigureId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:comments ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:rawFigureId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:xMin ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:propertyY ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:double ;
            owl:onProperty sd:xMax ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:double ;
            owl:onProperty sd:xMin ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:unitYString ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:yMin ],
        [ a owl:Restriction ;
            owl:allValuesFrom sd:Sample ;
            owl:onProperty sd:ofSample ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:yMax ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:figureName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty sd:pointCount ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:xMax ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:yMin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:unitYString ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:propertyY ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:double ;
            owl:onProperty sd:yMax ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:pointCount ],
        sd:HasIngestionProvenance ;
    skos:definition """A measurement curve digitized from a figure in the source paper. Phase 1
keeps raw x/y arrays as JSON literals plus pre-computed aggregates
(xMin/Max/yMin/Max/pointCount) for fast range filtering.
""" ;
    skos:exactMatch prov:Entity,
        sd:Curve ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:Periodical a owl:Class ;
    rdfs:label "Periodical" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:alternateName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:alternateName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:periodicalName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:periodicalName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:periodicalSlug ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:periodicalName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:alternateName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:periodicalSlug ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:periodicalSlug ] ;
    skos:definition "A journal / book series the paper appears in." ;
    skos:exactMatch <http://schema.org/Periodical> ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:familyName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:personCompositeKey ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:familyName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:personCompositeKey ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:givenName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:givenName ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:personCompositeKey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:givenName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:familyName ] ;
    skos:definition "An author or other PROV-O agent linked to a paper." ;
    skos:exactMatch <http://schema.org/Person>,
        prov:Agent ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:author a owl:ObjectProperty ;
    rdfs:label "author" ;
    rdfs:range sd:Person ;
    skos:definition "論文著者 (順序保持; ABox では index でユニーク化)" ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:hasDescriptor a owl:ObjectProperty ;
    rdfs:label "hasDescriptor" ;
    rdfs:range sd:Descriptor ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:Descriptor a owl:Class ;
    rdfs:label "Descriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:descriptorCompositeKey ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:descriptorCategory ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:descriptorCategory ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:descriptorName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:descriptorComment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:descriptorExtracted ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:descriptorCategory ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:descriptorName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:descriptorComment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:descriptorName ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:descriptorCompositeKey ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:descriptorExtracted ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:descriptorExtracted ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:descriptorCompositeKey ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:descriptorComment ] ;
    skos:definition """Structured metadata extracted from the sample_info JSON column
(MaterialFamily, Form, FabricationProcess, etc.). Entries with empty
category/comment/extracted are dropped at ingest time.
""" ;
    skos:exactMatch sd:Descriptor ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:HasIngestionProvenance a owl:Class ;
    rdfs:label "HasIngestionProvenance" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sd:IngestionActivity ;
            owl:onProperty sd:wasGeneratedBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:wasGeneratedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:wasGeneratedBy ] ;
    skos:definition """Marker mixin: any Paper/Sample/Curve gets prov:wasGeneratedBy pointing
at the IngestionActivity that emitted it. Concrete classes inherit the
`wasGeneratedBy` slot.
""" ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:IngestionActivity a owl:Class ;
    rdfs:label "IngestionActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:endedAtTime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:used ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:runId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:used ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty sd:atTime ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:wasAssociatedWith ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty sd:used ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:runId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:endedAtTime ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:atTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty sd:wasAssociatedWith ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:atTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty sd:endedAtTime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:wasAssociatedWith ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:runId ] ;
    skos:definition """A single run of the csv2rdf-mcp ingester. Each Paper/Sample/Curve
generated in the run carries prov:wasGeneratedBy → IngestionActivity for
provenance traceability.
""" ;
    skos:exactMatch prov:Activity,
        sd:IngestionActivity ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:Paper a owl:Class ;
    rdfs:label "Paper" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:pages ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:volume ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:datePublished ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:SID ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:author ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:SID ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty sd:datePublished ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:issue ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:volume ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:doi ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:publisher ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:publisher ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:issue ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:projectName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty sd:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:datePublished ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:publisher ],
        [ a owl:Restriction ;
            owl:allValuesFrom sd:Person ;
            owl:onProperty sd:author ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:doi ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:SID ],
        [ a owl:Restriction ;
            owl:allValuesFrom sd:Periodical ;
            owl:onProperty sd:isPartOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:pages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:pages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:issue ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:volume ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:doi ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:projectName ],
        sd:HasIngestionProvenance ;
    skos:definition """A scholarly article that contains digitized measurement data. Each row
in starrydata_papers.csv becomes one sd:Paper instance.
""" ;
    skos:exactMatch <http://schema.org/ScholarlyArticle>,
        prov:Entity,
        sd:Paper ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:SID a owl:DatatypeProperty ;
    rdfs:label "SID" ;
    rdfs:range xsd:string ;
    skos:definition "starrydata paper identifier (SID 列の値)" ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:Sample a owl:Class ;
    rdfs:label "Sample" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:hasDescriptor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:rawSampleId ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:sampleCompositeKey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:compositionDetails ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:sampleName ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:sampleName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:compositionDetails ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom sd:Descriptor ;
            owl:onProperty sd:hasDescriptor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:sampleCompositeKey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:fromPaper ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:compositionString ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:sampleName ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:createdAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:allValuesFrom sd:Paper ;
            owl:onProperty sd:fromPaper ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:compositionString ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:sampleCompositeKey ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:compositionDetails ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:rawSampleId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:compositionString ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty sd:fromPaper ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty sd:rawSampleId ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty sd:modifiedAt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty sd:createdAt ],
        sd:HasIngestionProvenance ;
    skos:definition """A physical specimen prepared and measured in a paper. Carries a
composition string and zero or more structured Descriptors.
""" ;
    skos:exactMatch prov:Entity,
        sd:Sample ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:alternateName a owl:DatatypeProperty ;
    rdfs:label "alternateName" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:atTime a owl:DatatypeProperty ;
    rdfs:label "atTime" ;
    rdfs:range xsd:dateTime ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:comments a owl:DatatypeProperty ;
    rdfs:label "comments" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:compositionDetails a owl:DatatypeProperty ;
    rdfs:label "compositionDetails" ;
    rdfs:range xsd:string ;
    skos:inScheme <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology> .

sd:compositionString a owl:DatatypeProperty ;
    rdfs:label "compositionString" ;
    rdfs:range xsd:string ;
